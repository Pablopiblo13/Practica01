@model IEnumerable<Practica01.Models.Campaign>

@{
    ViewData["Title"] = "Listado de Campañas";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h2>@ViewData["Title"]</h2>

<form method="get" asp-action="Index">
    <label>Categoría:</label>
    <select name="categoria">
        <option value="">Todas</option>
        <option value="Marketing">Marketing</option>
        <option value="Promoción">Promoción</option>
    </select>

    <label>Estado:</label>
    <select name="estado">
        <option value="">Todos</option>
        <option value="Activa">Activa</option>
        <option value="Inactiva">Inactiva</option>
    </select>

    <button type="submit">Filtrar</button>
</form>

<table border="1" cellpadding="5" cellspacing="0">
    <thead>
        <tr>
            <th>Nombre</th>
            <th>Categoría</th>
            <th>Estado</th>
            <th>Canal</th>
            <th>Descuento</th>
            <th>Fechas</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
    @foreach (var campaign in Model)
    {
        <tr>
            <td>@campaign.Nombre</td>
            <td>@campaign.Categoria</td>
            <td>@campaign.Estado</td>
            <td>@campaign.Canal</td>
            <td>@campaign.Descuento %</td>
            <td>@campaign.FechaInicio.ToShortDateString() - @campaign.FechaFin.ToShortDateString()</td>
            <td>
                <a asp-action="Details" asp-route-id="@campaign.Id">Ver detalle</a>
            </td>
        </tr>
    }
    </tbody>
</table>